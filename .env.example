# Connection string dari Neon (Dashboard -> Project -> Connect).
# Pastiin pake yang "pooled connection" kalau Neon nawarin pilihan itu.
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/expense_tracker?sslmode=require"

# Passcode buat login. Ganti ke sesuatu yang cuma lo yang tau -- ini
# bukan tempat buat "admin123".
APP_PASSCODE="ganti-ini"

# Secret buat nandatangani session JWT. WAJIB minimal 32 karakter acak.
# Generate dengan: openssl rand -base64 32
APP_COOKIE_SECRET="ganti-ini-juga-minimal-32-karakter-acak"
